# --- Database (local Docker stack) ---
# PG_PORT is the host port docker-compose binds (override if 5432 is taken).
PG_PORT=5433
DATABASE_URL=postgresql+psycopg://sourcing:sourcing@localhost:5433/sourcing

# --- LLM (Ollama) ---
# The Buy-Box agent talks to a local Ollama server. The model MUST support tool calling.
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
AGENT_MODEL=gpt-oss:20b

# --- Embeddings ---
# hash  -> deterministic, dependency-free, offline default (used by the unit suite)
# ollama -> live embeddings via an Ollama embedding model (e.g. nomic-embed-text)
EMBED_PROVIDER=hash
EMBED_MODEL=nomic-embed-text
# pgvector column dim must match the active provider's output dim.
# hash provider: any value (default 384). nomic-embed-text: 768.
EMBED_DIM=384

# --- Agent loop ---
MAX_CLARIFYING_QUESTIONS=6

# --- ABN Lookup API ---
# Register at https://abr.business.gov.au/Tools/WebServices to obtain a GUID.
ABN_LOOKUP_GUID=

# ASIC company dataset — local CSV path for dev (production CKAN-resolves from data.gov.au)
ASIC_CSV_PATH=

# Apify token for scrape connectors (Google Maps, Yellow Pages, Website, LinkedIn)
APIFY_API_TOKEN=
